# Astropress environment template
# Copy to .env and fill in your values

# ── Runtime mode ─────────────────────────────────────────────────────────────
ASTROPRESS_RUNTIME_MODE=local
ASTROPRESS_LOCAL_PROVIDER=sqlite
ASTROPRESS_APP_HOST=vercel
ASTROPRESS_CONTENT_SERVICES=none

# ── Session + auth ───────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-session-secret
ADMIN_PASSWORD=replace-with-your-admin-password
EDITOR_PASSWORD=replace-with-your-editor-password

# ── Database ─────────────────────────────────────────────────────────────────
ADMIN_DB_PATH=.data/admin.sqlite
