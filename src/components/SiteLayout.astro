---
interface NavLink {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  heading: string;
  eyebrow?: string;
  currentPath: string;
}

const { title, description, heading, eyebrow = "Astropress", currentPath } = Astro.props;

const navLinks: NavLink[] = [
  { href: "/", label: "Overview" },
  { href: "/docs", label: "Getting Started" },
  { href: "/providers", label: "Hosting" },
  { href: "/wordpress", label: "WordPress" },
  { href: "/operations", label: "Operations" },
  { href: "/admin", label: "Admin" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light;
        --page-bg: #f2efe4;
        --panel: rgba(255, 255, 255, 0.82);
        --panel-strong: #fffdf7;
        --text: #1f2b24;
        --muted: #5d665f;
        --line: rgba(34, 53, 43, 0.14);
        --accent: #1f5f4a;
        --accent-soft: #d9ebe3;
        --shadow: 0 20px 50px rgba(31, 43, 36, 0.08);
      }

      html {
        font-family: Georgia, "Times New Roman", serif;
        background:
          radial-gradient(circle at top left, rgba(177, 207, 181, 0.45), transparent 28rem),
          linear-gradient(180deg, #ebe6d5 0%, var(--page-bg) 100%);
        color: var(--text);
      }

      body {
        margin: 0;
      }

      a {
        color: var(--accent);
      }

      .skip-link {
        position: absolute;
        left: 1rem;
        top: -3rem;
        background: var(--accent);
        color: #fff;
        padding: 0.7rem 1rem;
      }

      .skip-link:focus {
        top: 1rem;
      }

      .shell {
        max-width: 72rem;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 4rem;
      }

      .masthead {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 0 1.5rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        text-decoration: none;
        color: inherit;
      }

      .brand-mark {
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 0.75rem;
        background:
          linear-gradient(145deg, rgba(31, 95, 74, 0.95), rgba(98, 142, 117, 0.92)),
          #1f5f4a;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.22);
      }

      .brand-copy strong {
        display: block;
        font-size: 1.05rem;
      }

      .brand-copy span {
        color: var(--muted);
        font-size: 0.92rem;
      }

      nav ul {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin: 0;
        padding: 0;
      }

      nav a {
        display: inline-flex;
        align-items: center;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        text-decoration: none;
        color: var(--text);
        border: 1px solid transparent;
      }

      nav a[aria-current="page"] {
        background: var(--panel-strong);
        border-color: var(--line);
        box-shadow: var(--shadow);
      }

      .hero {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 1.7rem;
        padding: 1.75rem;
        box-shadow: var(--shadow);
        backdrop-filter: blur(6px);
      }

      .eyebrow {
        margin: 0 0 0.5rem;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.78rem;
        font-weight: 700;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3.35rem);
        line-height: 1.05;
      }

      .hero p:last-child {
        margin-bottom: 0;
      }

      .content {
        margin-top: 1.25rem;
        display: grid;
        gap: 1rem;
      }

      .panel-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
        gap: 1rem;
      }

      .panel,
      .status-table {
        background: var(--panel-strong);
        border: 1px solid var(--line);
        border-radius: 1.25rem;
        padding: 1.25rem;
        box-shadow: var(--shadow);
      }

      .panel h2,
      .panel h3 {
        margin-top: 0;
      }

      .status-table table {
        width: 100%;
        border-collapse: collapse;
      }

      .status-table th,
      .status-table td {
        text-align: left;
        padding: 0.8rem 0;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }

      .status-table tr:last-child th,
      .status-table tr:last-child td {
        border-bottom: 0;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.2rem 0.6rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.04em;
      }

      .badge-supported {
        background: #dff1e8;
        color: #154d39;
      }

      .badge-preview {
        background: #f7ebc7;
        color: #755500;
      }

      .badge-limited {
        background: #f6ddd8;
        color: #8c2e1d;
      }

      .action-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1rem;
      }

      .action-row a {
        display: inline-flex;
        padding: 0.75rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        border: 1px solid var(--line);
        background: var(--panel-strong);
      }

      .action-row a.primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }

      code {
        background: var(--accent-soft);
        padding: 0.12rem 0.35rem;
        border-radius: 0.35rem;
      }

      ul,
      ol {
        padding-left: 1.2rem;
      }

      footer {
        margin-top: 1.5rem;
        color: var(--muted);
        font-size: 0.94rem;
      }

      @media (max-width: 720px) {
        .masthead {
          align-items: flex-start;
          flex-direction: column;
        }

        nav ul {
          gap: 0.45rem;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="shell">
      <header class="masthead">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-copy">
            <strong>Astropress</strong>
            <span>Simple-site web app framework with a real admin</span>
          </span>
        </a>
        <nav aria-label="Primary">
          <ul>
            {navLinks.map((link) => (
              <li>
                <a href={link.href} aria-current={currentPath === link.href ? "page" : undefined}>{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </header>

      <main id="main">
        <section class="hero">
          <p class="eyebrow">{eyebrow}</p>
          <h1>{heading}</h1>
          <p>{description}</p>
          <slot name="hero" />
        </section>
        <div class="content">
          <slot />
        </div>
      </main>

      <footer>
        Astropress is for editorial, informational, campaign, brochure, and blog sites with a clear content model.
      </footer>
    </div>
  </body>
</html>
